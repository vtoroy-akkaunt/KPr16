<Page x:Class="KPr16.PageGame"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:KPr16"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageGame">

    <StackPanel Orientation="Vertical">
        <DataGrid x:Name="c_front" SelectionMode="Single" IsReadOnly="True" Height="200">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="image" Width="SizeToCells">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding basepart-image}" 
                               Width="60" Height="60" 
                               Margin="5"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <DataGrid x:Name="c_items" SelectionMode="Single" IsReadOnly="True" MouseDoubleClick="c_items_MouseDoubleClick" Height="150"></DataGrid>
        <TextBlock x:Name="event_log" TextWrapping="Wrap" Height="50"></TextBlock>
        <StackPanel Orientation="Horizontal">
            <Button x:Name="btn_skip" IsEnabled="False" Click="btn_skip_Click">Пропустить</Button>
            <Button x:Name="btn_take" IsEnabled="False" Click="btn_take_Click">Взять</Button>
        </StackPanel>
    </StackPanel>
</Page>
